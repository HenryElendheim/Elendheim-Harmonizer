    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Mic capsule -->
    <path
        android:fillColor="#35E0C8"
        android:pathData="M44,40 A10,10 0 0 1 64,40 L64,48 A10,10 0 0 1 44,48 Z" />

    <!-- Cradle -->
    <path
        android:strokeColor="#35E0C8"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M38,50 A16,16 0 0 0 70,50" />

    <!-- Stem -->
    <path
        android:strokeColor="#35E0C8"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M54,66 L54,74" />

    <!-- Base -->
    <path
        android:strokeColor="#35E0C8"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M46,74 L62,74" />

    <!-- The stacked fifth, hinted as a small note above the mic. -->
    <path
        android:fillColor="#F2A63B"
        android:pathData="M74,30 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" />
